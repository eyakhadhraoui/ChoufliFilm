<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.Bloom?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.effect.Glow?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.LinearGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.chouflifilm.controller.user.frontController">


    <top>
        <!-- Navigation Bar with Enhanced Professional Design -->
        <VBox spacing="0" style="-fx-background-color: transparent;">
            <!-- Top Info Bar with Refined Blue Gradient -->
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: linear-gradient(to right, #00008B, #0000FF); -fx-background-radius: 0 0 20 20;" styleClass="top-info-bar">
                <padding>
                    <Insets bottom="10" left="25" right="25" top="10" />
                </padding>

                <Label style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-family: 'Segoe UI';" styleClass="info-text" text="123 Esprit, Elghazela, Tunisie">

                    <effect>
                        <Glow level="0.2" />
                    </effect>
                </Label>

                <Label style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-family: 'Segoe UI';" styleClass="info-text" text="+216 24 705 213">

                    <effect>
                        <Glow level="0.2" />
                    </effect>
                </Label>

                <Label style="-fx-text-fill: #ffffff; -fx-font-weight: 600; -fx-font-family: 'Segoe UI';" styleClass="info-text" text="ChouFliFilm@gmail.com">

                    <effect>
                        <Glow level="0.2" />
                    </effect>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Social Media Icons with Elevated Design -->
                <HBox alignment="CENTER_RIGHT" spacing="12">
                    <Button style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 50%; -fx-min-width: 32px; -fx-min-height: 32px; -fx-max-width: 32px; -fx-max-height: 32px;" styleClass="social-btn">

                        <effect>
                            <DropShadow color="rgba(0,0,0,0.25)" height="6" radius="2.5" width="6" />
                        </effect>
                    </Button>
                    <Button style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 50%; -fx-min-width: 32px; -fx-min-height: 32px; -fx-max-width: 32px; -fx-max-height: 32px;" styleClass="social-btn">

                        <effect>
                            <DropShadow color="rgba(0,0,0,0.25)" height="6" radius="2.5" width="6" />
                        </effect>
                    </Button>
                    <Button style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 50%; -fx-min-width: 32px; -fx-min-height: 32px; -fx-max-width: 32px; -fx-max-height: 32px;" styleClass="social-btn">

                        <effect>
                            <DropShadow color="rgba(0,0,0,0.25)" height="6" radius="2.5" width="6" />
                        </effect>
                    </Button>
                    <Button style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 50%; -fx-min-width: 32px; -fx-min-height: 32px; -fx-max-width: 32px; -fx-max-height: 32px;" styleClass="social-btn">
                        <graphic>
                            <ImageView fitHeight="16" fitWidth="16">
                                <Image url="@../images/insta.png" />
                                <effect>
                                    <Bloom threshold="0.2" />
                                </effect>
                            </ImageView>
                        </graphic>
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.25)" height="6" radius="2.5" width="6" />
                        </effect>
                    </Button>
                    <Button style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 50%; -fx-min-width: 32px; -fx-min-height: 32px; -fx-max-width: 32px; -fx-max-height: 32px;" styleClass="social-btn">

                        <effect>
                            <DropShadow color="rgba(0,0,0,0.25)" height="6" radius="2.5" width="6" />
                        </effect>
                    </Button>
                </HBox>
            </HBox>

            <!-- Main Navigation with Premium Glassmorphism Effect -->
            <HBox alignment="CENTER" prefHeight="80.0" prefWidth="1000.0" spacing="18" style="-fx-background-color: rgba(245, 250, 255, 0.92); -fx-background-radius: 0 0 30 30; -fx-border-color: rgba(200, 220, 240, 0.5); -fx-border-width: 0 0 1 0;" styleClass="main-nav">
                <padding>
                    <Insets bottom="15" left="25" right="25" top="15" />
                </padding>

                <!-- Logo with Premium Glow Effect -->
                <StackPane>
                    <ImageView fitHeight="70.0" fitWidth="150.0" styleClass="logo">
                        <image>
                            <Image url="@../images/logo.png" />
                        </image>
                    </ImageView>
                    <effect>
                        <Glow level="0.3">
                            <input>
                                <DropShadow color="#00008B" height="15" radius="7" spread="0.05" width="15" />
                            </input>
                        </Glow>
                    </effect>
                </StackPane>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Navigation Buttons with Elegant Design -->
                <Button style="-fx-background-color: transparent; -fx-text-fill: #00008B; -fx-font-size: 14px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI'; -fx-padding: 8 18; -fx-border-radius: 22; -fx-background-radius: 22;" styleClass="nav-btn" text="Home">
                    <effect>
                        <DropShadow color="rgba(0,0,139,0.1)" height="5" radius="2" width="5" />
                    </effect>
                </Button>
                <Button style="-fx-background-color: transparent; -fx-text-fill: #00008B; -fx-font-size: 14px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI'; -fx-padding: 8 18; -fx-border-radius: 22; -fx-background-radius: 22;" styleClass="nav-btn" text="About">
                    <effect>
                        <DropShadow color="rgba(0,0,139,0.1)" height="5" radius="2" width="5" />
                    </effect>
                </Button>
                <Button style="-fx-background-color: transparent; -fx-text-fill: #00008B; -fx-font-size: 14px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI'; -fx-padding: 8 18; -fx-border-radius: 22; -fx-background-radius: 22;" styleClass="nav-btn" text="Films">
                    <effect>
                        <DropShadow color="rgba(0,0,139,0.1)" height="5" radius="2" width="5" />
                    </effect>
                </Button>
                <Button onAction="#pageassociation" style="-fx-background-color: transparent; -fx-text-fill: #00008B; -fx-font-size: 14px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI'; -fx-padding: 8 18; -fx-border-radius: 22; -fx-background-radius: 22;" styleClass="nav-btn" text="Bénévolat">
                    <effect>
                        <DropShadow color="rgba(0,0,139,0.1)" height="5" radius="2" width="5" />
                    </effect>
                </Button>
                <Button onAction="#pageReclamation" style="-fx-background-color: transparent; -fx-text-fill: #00008B; -fx-font-size: 14px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI'; -fx-padding: 8 18; -fx-border-radius: 22; -fx-background-radius: 22;" styleClass="nav-btn" text="Réclamations">
                    <effect>
                        <DropShadow color="rgba(0,0,139,0.1)" height="5" radius="2" width="5" />
                    </effect>
                </Button>
                <!-- Active Navigation Button with Premium Effect -->

                <Button style="-fx-background-color: transparent; -fx-text-fill: #00008B; -fx-font-size: 14px; -fx-font-weight: 600; -fx-font-family: 'Segoe UI'; -fx-padding: 8 18; -fx-border-radius: 22; -fx-background-radius: 22;" styleClass="nav-btn" text="Blogs">
                    <effect>
                        <DropShadow color="rgba(0,0,139,0.1)" height="5" radius="2" width="5" />
                    </effect>
                </Button>

                <!-- Cart Button with Premium 3D Effect -->
                <Button style="-fx-background-color: rgba(220,230,240,0.9); -fx-text-fill: #00008B; -fx-font-weight: 600; -fx-background-radius: 22; -fx-padding: 8 18; -fx-font-family: 'Segoe UI';" styleClass="cart-btn" text="Panier">

                    <effect>
                        <DropShadow color="rgba(0,0,139,0.2)" height="8.0" radius="3.5" width="8.0" />
                    </effect>
                </Button>

                <!-- Notification Button with Premium Look -->
                <StackPane>
                    <Button style="-fx-background-color: rgba(220,230,240,0.9); -fx-background-radius: 50%; -fx-min-width: 38px; -fx-min-height: 38px; -fx-max-width: 38px; -fx-max-height: 38px;" styleClass="notification-btn">

                        <effect>
                            <DropShadow color="rgba(0,0,139,0.2)" height="8" radius="3.5" width="8" />
                        </effect>
                    </Button>
                    <Label style="-fx-background-color: #0000FF; -fx-text-fill: white; -fx-background-radius: 50%; -fx-min-width: 18px; -fx-min-height: 18px; -fx-alignment: center; -fx-font-weight: bold; -fx-font-family: 'Segoe UI'; -fx-font-size: 10px;" styleClass="notification-count" text="0">
                        <StackPane.margin>
                            <Insets left="20.0" top="-20.0" />
                        </StackPane.margin>
                    </Label>
                </StackPane>
                <ImageView fx:id="imageView" fitHeight="50.0" fitWidth="50.0" onMouseClicked="#pageupdateFront" />

                <!-- Logout Button with Premium Gradient -->
                <Button style="-fx-background-color: linear-gradient(to right, #00008B, #0000FF); -fx-text-fill: white; -fx-font-weight: 600; -fx-background-radius: 22; -fx-padding: 8 18; -fx-font-family: 'Segoe UI';" styleClass="logout-btn" text="Logout" onAction="#logout">

                    <effect>
                        <DropShadow color="#00008B" height="8" radius="3.5" width="8" />
                    </effect>
                </Button>
            </HBox>
        </VBox>
    </top>

    <center>
        <!-- Main Content Area with Full Screen Background Image -->
        <StackPane style="-fx-background-color: black;" styleClass="main-content-area">
            <!-- Background Image with Blur Effect -->
            <ImageView styleClass="hero-background" preserveRatio="false" StackPane.alignment="CENTER">
                <!-- Remove fixed dimensions to allow full screen stretch -->
                <Image url="@../images/cinema5.jpg" />
                <effect>
                    <GaussianBlur radius="3.0">
                        <input>
                            <ColorAdjust brightness="-0.1" contrast="0.1" hue="0.0" saturation="-0.2" />
                        </input>
                    </GaussianBlur>
                </effect>
                <!-- Important: Set these properties to fill the entire StackPane -->
                <fitWidth>
                    <StackPane fx:constant="USE_PREF_SIZE" />
                </fitWidth>
                <fitHeight>
                    <StackPane fx:constant="USE_PREF_SIZE" />
                </fitHeight>
            </ImageView>

            <!-- Overlay with Professional Semi-transparent Gradient -->
            <Rectangle style="-fx-fill: linear-gradient(to bottom, rgba(0,0,0,0.6), rgba(0,0,0,0.6));"  />

            <!-- Main Content Container -->
            <VBox alignment="CENTER" spacing="30">
                <!-- Heading Text -->
                <Label style="-fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold;" text="Enjoy Your Watch With">
                    <font>
                        <Font size="50.0" />
                    </font>
                    <effect>
                        <DropShadow color="rgba(0,0,0,0.5)" height="10" radius="4.5" width="10" />
                    </effect>
                </Label>

                <Label style="-fx-text-fill: white; -fx-font-family: 'Segoe UI'; -fx-font-weight: bold;" text="ChouFliFilm">
                    <font>
                        <Font size="60.0" />
                    </font>
                    <effect>
                        <DropShadow color="rgba(0,0,0,0.5)" height="10" radius="4.5" width="10" />
                    </effect>
                </Label>

                <!-- Search Bar -->
                <HBox alignment="CENTER" prefHeight="70.0" prefWidth="600.0" spacing="0">
                    <TextField fx:id="searchField" prefHeight="50.0" prefWidth="400.0" promptText="Eg: Tunisia" style="-fx-background-color: white; -fx-background-radius: 25 0 0 25; -fx-border-radius: 25 0 0 25; -fx-padding: 10; -fx-font-size: 14px;">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.3)" height="8" radius="3.5" width="8" />
                        </effect>
                    </TextField>
                    <Button fx:id="searchButton" prefHeight="50.0" prefWidth="100.0" style="-fx-background-color: linear-gradient(to right, #00008B, #0000FF); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 0 25 25 0; -fx-border-radius: 0 25 25 0;" text="Search">
                        <effect>
                            <DropShadow color="rgba(0,0,0,0.3)" height="8" radius="3.5" width="8" />
                        </effect>
                    </Button>
                </HBox>
            </VBox>

            <!-- Réclamation Form Container (Empty for now, will be filled dynamically) -->
            <VBox fx:id="reclamationContainer" alignment="CENTER" maxWidth="1500.0" minWidth="700.0" prefWidth="1500.0" spacing="25" style="-fx-background-radius: 20; -fx-border-radius: 20;" styleClass="form-container">
                <padding>
                    <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
                </padding>
                <!-- Action Buttons -->
                <HBox alignment="CENTER" spacing="15" />

                <StackPane.margin>
                    <Insets bottom="50.0" top="30.0" />
                </StackPane.margin>
            </VBox>
        </StackPane>
    </center>

    <!-- Footer with subtle gradient -->
    <bottom>
        <HBox alignment="CENTER" spacing="10" style="-fx-background-color: linear-gradient(to right, rgba(0,0,139,0.95), rgba(0,0,255,0.95)); -fx-padding: 12px;">
            <Label style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-family: 'Segoe UI';" text="© 2025 ChouFliFilm. Tous droits réservés." />
        </HBox>
    </bottom>
</BorderPane>